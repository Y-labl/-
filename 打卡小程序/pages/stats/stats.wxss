/* pages/stats/stats.wxss */

/* ========== 周期选择器 ========== */
.period-selector {
  display: flex;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(233, 30, 99, 0.06);
  border: 1rpx solid rgba(248, 215, 228, 0.9);
}

.period-btn {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.period-btn-active {
  background: linear-gradient(135deg, #ec407a 0%, #e91e63 100%);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(233, 30, 99, 0.25);
}

/* ========== 统计卡片 ========== */
.stats-card {
  background: linear-gradient(135deg, #f06292 0%, #e91e63 55%, #d81b60 100%);
  color: #ffffff;
  overflow: hidden;
}

.stats-card::before {
  display: none;
}

.stats-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.stats-period {
  font-size: 28rpx;
  opacity: 0.9;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-tile {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  padding: 22rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.stats-tile-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.15;
}

.stats-tile-num.text-primary {
  color: #fff9c4;
}

.stats-tile-num.text-money {
  color: #fff9c4;
  font-size: 36rpx;
}

.stats-tile-label {
  font-size: 22rpx;
  opacity: 0.88;
  margin-top: 10rpx;
  text-align: center;
}

.stats-sub {
  display: flex;
  justify-content: space-between;
}

.stats-sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-sub-label {
  font-size: 22rpx;
  opacity: 0.75;
}

.stats-sub-num {
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

/* ========== 考勤周期卡片 ========== */
.cycle-card {
  padding: 28rpx;
  background: linear-gradient(180deg, #fffafd 0%, #ffffff 100%);
  border: 1rpx solid #f8d7e4;
}

.cycle-card::before {
  display: none;
}

.cycle-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.cycle-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.cycle-sub {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.cycle-range {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #e91e63;
  margin-bottom: 20rpx;
}

.cycle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #fce4ec;
}

.cycle-row:last-of-type {
  border-bottom: none;
}

.cycle-row.highlight {
  background: rgba(233, 30, 99, 0.06);
  margin: 8rpx -12rpx 0;
  padding: 18rpx 12rpx;
  border-radius: 16rpx;
  border-bottom: none;
}

.cycle-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cycle-strong {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.cycle-money {
  font-size: 32rpx;
  font-weight: 800;
  color: #e91e63;
}

.cycle-hint {
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.5;
  margin-bottom: 8rpx;
}

/* ========== 目标卡片 ========== */
.goal-card {
  background: linear-gradient(135deg, #fff7e6 0%, #fff3d9 100%);
  border: 2rpx solid #ffe4b3;
}

.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #b38600;
}

.goal-progress-text {
  font-size: 26rpx;
  color: #b38600;
}

.goal-progress-bar {
  height: 16rpx;
  background: rgba(255, 193, 7, 0.3);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goal-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #faad14, #ffc53d);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.goal-footer {
  display: flex;
  justify-content: space-between;
}

.goal-remaining {
  font-size: 24rpx;
  color: #b38600;
}

.goal-eta {
  font-size: 24rpx;
  color: #8b6914;
}

/* ========== 图表卡片 ========== */
.chart-card {
  padding: 24rpx;
}

.chart-header {
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.chart-container {
  position: relative;
}

.chart-placeholder {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: var(--text-light);
  font-size: 26rpx;
}

/* ========== 明细列表 ========== */
.list-card {
  padding: 24rpx;
}

.list-header {
  margin-bottom: 20rpx;
}

.list-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-header-year .list-header-row {
  width: 100%;
}

.list-cycle-hint {
  font-size: 22rpx;
  color: #ad1457;
  line-height: 1.4;
  padding-right: 8rpx;
  opacity: 0.92;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.list-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.records-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  position: relative;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
  margin-right: 20rpx;
}

.record-day {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.record-week {
  font-size: 20rpx;
  color: var(--text-light);
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-points {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.record-points.record-vacation {
  color: var(--warning-color);
}

.record-money {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.record-subsidy {
  font-size: 22rpx;
  color: #e91e63;
  font-weight: 600;
  margin-top: 4rpx;
}

.record-subsidy.record-tip {
  color: #7b1fa2;
}

.record-item-month {
  opacity: 0.96;
}

.record-month-total {
  font-weight: 700;
  color: #c2185b;
  font-size: 24rpx;
}

.record-remark {
  flex: 1;
  margin: 0 20rpx;
  font-size: 22rpx;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

/* ========== 快捷入口卡片 ========== */
.calculator-card,
.share-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-top: 0;
}

.calculator-info,
.share-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.calculator-icon,
.share-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.calculator-detail,
.share-detail {
  display: flex;
  flex-direction: column;
}

.calculator-title,
.share-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.calculator-desc,
.share-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.calculator-arrow,
.share-arrow {
  font-size: 36rpx;
  color: var(--text-light);
}

/* ========== 计算器弹窗 ========== */
.calculator-modal {
  padding: 40rpx;
}

.calc-section {
  margin-bottom: 30rpx;
}

.calc-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.calc-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

.calc-result {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #fff5f8 0%, #ffe8f0 100%);
  border-radius: 16rpx;
  border: 1rpx solid #fce4ec;
}

.calc-result-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.calc-result-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.calc-result-box {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.calc-result-item {
  flex: 1;
  background: linear-gradient(135deg, #ec407a 0%, #e91e63 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(233, 30, 99, 0.2);
}

.calc-result-item:last-child {
  background: linear-gradient(135deg, #ffb74d 0%, #ffa726 100%);
  box-shadow: 0 6rpx 16rpx rgba(255, 167, 38, 0.25);
}

.calc-result-label {
  font-size: 22rpx;
  opacity: 0.85;
  display: block;
  margin-bottom: 8rpx;
}

.calc-result-money {
  font-size: 32rpx;
  font-weight: 700;
}

.calc-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light);
}

/* ========== 空状态 ========== */
.empty-state {
  padding: 60rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-light);
}
